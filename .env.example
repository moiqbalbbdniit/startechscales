# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/
MONGODB_DB_NAME=star_tech_scales

# Authentication - generate a long random value; never use the example value in production
AUTH_SECRET=replace-with-a-long-random-secret

# ImageKit (private key must never use NEXT_PUBLIC_)
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxx
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxx
